# ── Required secrets ──────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_HEX_STRING

# OpenAI
OPENAI_API_KEY=sk-...

# ── Optional overrides (defaults shown) ───────────────────────
OPENAI_MODEL=gpt-4o-mini

# Bayesian Optimization
BO_BATCH_SIZE=8

# Session control
SESSION_TIMEOUT_MINUTES=20
PARETO_FRONT_TARGET=3

# CORS (comma-separated origins for local dev; in production set to your domain)
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Task config path (relative to working dir inside container)
TASKS_CONFIG_PATH=app/tasks/config.yaml

# Database (overridden in docker-compose.yml for container path)
# DATABASE_URL=sqlite+aiosqlite:////data/study.db

# Guest login (set to true to allow passwordless guest access)
# Guests are assigned task_sns with the badge condition by default.
# Each guest login creates a new unique account so sessions are never shared.
# GUEST_LOGIN_ENABLED=false
# GUEST_TASK_ID=task_sns
